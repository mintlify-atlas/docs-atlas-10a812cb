  "keyFeatures": [
    "Sequential step execution with fluent AddStep chaining",
    "Immutable record-based data bags (BagBase) for safe data flow",
    "Built-in and custom error handling via StepError and ThrowStepError",
    "Controlled flow with Next() and Stop() step methods",
    "Async-first design with Task-based ProcessAsync",
    "Branching pipelines with mid-pipeline ExecuteAsync checkpoints",
    "Dependency injection support via constructor injection in steps",
    "Automatic unhandled exception capture with IsUnhandledError flag"
  ],
